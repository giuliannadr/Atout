{
  "name": "atout",
  "productName": "atout",
  "description": "Tu estudio freelance, organizado. Para developers web y community managers.",
  "author": "atout",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "main": "electron/main.mjs",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "electron:dev": "cross-env BUILD_TARGET=electron vite build && electron .",
    "electron:watch": "concurrently \"vite\" \"cross-env ELECTRON_ENV=development electron .\"",
    "electron:build": "cross-env BUILD_TARGET=electron npm run build && electron-builder --config electron-builder.config.mjs",
    "electron:build:win": "cross-env BUILD_TARGET=electron npm run build && electron-builder --win --config electron-builder.config.mjs",
    "electron:build:mac": "cross-env BUILD_TARGET=electron npm run build && electron-builder --mac --config electron-builder.config.mjs",
    "electron:pack:portable": "cross-env BUILD_TARGET=electron npm run build && electron-builder --win dir --config electron-builder.config.mjs",
    "docker:build": "docker compose build",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down",
    "docker:logs": "docker compose logs -f"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.105.4",
    "@tailwindcss/forms": "^0.5.11",
    "autoprefixer": "^10.5.0",
    "date-fns": "^4.1.0",
    "html2canvas": "^1.4.1",
    "jspdf": "^4.2.1",
    "lucide-react": "^1.14.0",
    "postcss": "^8.5.14",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-router-dom": "^7.15.0",
    "tailwindcss": "^4.3.0",
    "zustand": "^5.0.13"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@tailwindcss/postcss": "^4.3.0",
    "@types/node": "^24.12.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "canvas": "^3.2.3",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron": "^42.0.1",
    "electron-builder": "^26.8.1",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.59.2",
    "vite": "^8.0.12",
    "vite-plugin-pwa": "^1.3.0"
  }
}
